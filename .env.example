# Database Configuration Template (Local Docker & App)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_strong_password_here
DB_DATABASE=ev_prices

# TeslaMate Database (External)
TESLAMATE_DB_HOST=localhost
TESLAMATE_DB_PORT=5432
TESLAMATE_DB_USERNAME=teslamate
TESLAMATE_DB_PASSWORD=secret_password
TESLAMATE_DB_DATABASE=teslamate

# TeslaMate Geofence for Home Charging
TESLAMATE_HOME_GEOFENCE_NAME=Home

# Default Pricing Configuration (PLN Gross per kWh)
# Fixed Energy Price (e.g. current frozen G11 energy price ~0.50 net + 23% VAT)
DEFAULT_FIXED_ENERGY_PRICE=0.615
# Variable Transmission Fee (Sum of variable distribution, quality fee, etc. ~0.43 PLN gross)
DEFAULT_TRANSMISSION_FEE=0.430
# Dynamic Provider Margin (e.g. margin added by providers like pstryk.pl ~0.05 PLN gross)
DEFAULT_PROVIDER_MARGIN=0.050
